#!/usr/bin/env bash
set -euo pipefail

REMOTE="${CLIP_REMOTE:-styreep@100.73.150.52}"
MAC_PATH='PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"'

usage() {
    cat >&2 <<'EOF'
usage: mac-clipboard paste-image|paste-text|copy-text

Bridge the macOS clipboard into this headless Arch session over the reverse SSH
link. Override the mac host with CLIP_REMOTE.
EOF
}

ssh_mac() {
    ssh -F /dev/null -o ConnectTimeout=5 -o BatchMode=yes "$REMOTE" "$@"
}

case "${1:-}" in
    paste-image)
        ssh_mac "$MAC_PATH; command -v pngpaste >/dev/null 2>&1 && pngpaste -"
        ;;
    paste-text)
        ssh_mac "$MAC_PATH; pbpaste"
        ;;
    copy-text)
        ssh_mac "$MAC_PATH; pbcopy"
        ;;
    *)
        usage
        exit 2
        ;;
esac
