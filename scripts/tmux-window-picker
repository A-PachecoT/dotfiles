#!/bin/bash
# Quick window switcher + file finder (Cmd+E) — command palette style
# Windows appear instantly, files load async in background via fd
# Select window → switch to it | Select file → open with smart-open

set -euo pipefail

RESULT_FILE="/tmp/tmux-window-target"
rm -f "$RESULT_FILE"

# Capture the originating pane BEFORE the popup's fzf steals focus.
# Inside popups $TMUX_PANE is unset, so we rely on either:
#   1. TMUX_TRIGGER_PANE (set by the binding via `-e TMUX_TRIGGER_PANE=#{pane_id}`)
#   2. The attached client's currently-active pane (fallback)
# This is needed so smart-open.sh can find the yazi pane in the right window.
TRIGGER_PANE="${TMUX_TRIGGER_PANE:-$(tmux display-message -p '#{pane_id}' 2>/dev/null || true)}"

# Get pane cwd for file search context
PANE_CWD=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null || echo "$HOME")

# Feed windows (instant) + files (async) into fzf
{
    # Windows: instant, prefixed with "w:" for identification
    tmux list-windows -a -F "w:#{session_name}:#{window_index} #{session_name} > ##{window_index}: #{window_name}   #{pane_current_path}"

    # Files: async via fd, prefixed with "f:" — streams in as found
    fd --type f --hidden --exclude .git --exclude node_modules --exclude .venv --exclude __pycache__ \
        --max-depth 6 --color never . "$PANE_CWD" 2>/dev/null | \
        head -5000 | \
        while IFS= read -r f; do
            # Show relative path for readability
            rel="${f#"$PANE_CWD"/}"
            echo "f:$f   $rel"
        done &
} | \
    fzf --no-multi \
        --prompt="  " \
        --header="Switch window · Search files" \
        --layout=reverse \
        --height=100% \
        --border=none \
        --color="bg+:#33467c,fg:#c0caf5,fg+:#c0caf5,hl:#7aa2f7,hl+:#7aa2f7,prompt:#9ece6a,header:#565f89,pointer:#7aa2f7" \
        --with-nth=2.. \
        --delimiter=' ' \
        --preview='
            item={1}
            type=${item%%:*}
            if [ "$type" = "w" ]; then
                rest=${item#w:}
                session=${rest%%:*}
                idx=${rest#*:}
                echo -e "\033[1;34m Panes:\033[0m"
                tmux list-panes -t "$session:$idx" -F "  #{pane_index}: #{pane_current_command}  #{pane_current_path}" 2>/dev/null
            else
                fpath=${item#f:}
                head -40 "$fpath" 2>/dev/null || echo "(binary or unreadable)"
            fi
        ' \
        --preview-window=down,6,border-top | \
    cut -d' ' -f1 > "$RESULT_FILE" 2>/dev/null || true

# Handle selection
if [[ -f "$RESULT_FILE" && -s "$RESULT_FILE" ]]; then
    SELECTED=$(cat "$RESULT_FILE")
    TYPE="${SELECTED%%:*}"

    if [[ "$TYPE" == "w" ]]; then
        # Window: switch to it
        TARGET="${SELECTED#w:}"
        tmux switch-client -t "$TARGET" 2>/dev/null || true
    elif [[ "$TYPE" == "f" ]]; then
        # File: open with smart-open
        # Run synchronously — tmux reaps popup children on close, so `&` would
        # kill smart-open.sh before it can complete the yazi IPC call.
        # Forward the captured trigger pane as TMUX_PANE so smart-open.sh
        # targets the correct window's yazi pane.
        FILEPATH="${SELECTED#f:}"
        echo -n "$FILEPATH" | TMUX_PANE="$TRIGGER_PANE" ~/dotfiles/scripts/smart-open.sh
    fi

    rm -f "$RESULT_FILE"
fi
